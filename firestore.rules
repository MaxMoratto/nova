rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Administradores por correo (agrega más correos a la lista para dar acceso).
    function isAdmin() {
      return request.auth != null && request.auth.token.email in [
        'corteunicel@gmail.com',
        'adeangel268@gmail.com'
      ];
    }

    // Asientos: lectura pública (el mapa en vivo), escritura solo admin
    match /asientos_nova/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Peleas: lectura pública, escritura solo admin
    match /peleas/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Config (cupo general, etc.): lectura pública, escritura solo admin
    match /config/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Boletos:
    //  - get  (ver 1 boleto por su token/QR): público
    //  - list (contadores del escáner): cualquier staff logueado
    //  - update (marcar ingreso en la puerta): cualquier staff logueado
    //  - create/delete (emitir/borrar): solo admin
    match /boletos/{token} {
      allow get: if true;
      allow list: if request.auth != null;
      allow update: if request.auth != null;
      allow create, delete: if isAdmin();
    }

    // Órdenes de Mercado Pago:
    //  - get (la página de gracias muestra los boletos de la orden): público por su id
    //  - escritura: solo el servidor (Firebase Admin ignora las reglas) o admin
    match /ordenes/{id} {
      allow get: if true;
      allow list, write: if isAdmin();
    }
  }
}
